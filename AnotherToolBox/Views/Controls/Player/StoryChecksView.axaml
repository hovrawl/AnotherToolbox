    <Control.Resources>
        <Style x:Key="SharedTextBlockStyle" Selector="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <DataTemplate x:Key="StoryCheckTemplate" DataType="playerVm:StoryCheckViewModel">
            <player:StoryCheckView />
        </DataTemplate>
    </Control.Resources>
