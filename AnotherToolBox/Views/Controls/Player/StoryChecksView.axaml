    <!-- </Grid> -->
    <Grid RowDefinitions="Auto, *" Margin="8" RowSpacing="8">
        <Border BorderThickness="1" BorderBrush="DarkSlateGray" CornerRadius="4">
            <Button>Grouped</Button>
        </Border>
        <ScrollViewer Grid.Row="1"
                      HorizontalContentAlignment="Left"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsRepeater ItemsSource="{Binding GroupedChecks}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8" />
                </ItemsRepeater.Layout>  
                <ItemsRepeater.ItemTemplate>  
                    <DataTemplate>
                        <Grid RowDefinitions="Auto, Auto, *">
                            
                            <TextBlock Grid.Row="0" Text="{Binding Group}" FontWeight="Bold" />
                            <Border Grid.Row="1" BorderThickness="1" BorderBrush="DarkSlateGray" Margin="4"></Border>
                            <ScrollViewer Grid.Row="2" 
                                          HorizontalContentAlignment="Left"
                                          VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollBarVisibility="Auto">
                                <ItemsRepeater ItemsSource="{Binding Items}">
                                    <!-- Item template -->
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="8" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate DataType="playerVm:StoryCheckViewModel">
                                            <player:StoryCheckView />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </ScrollViewer>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>  
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</UserControl>
