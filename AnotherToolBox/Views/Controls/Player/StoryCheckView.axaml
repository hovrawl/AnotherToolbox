<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:player="clr-namespace:AnotherToolBox.ViewModels.Player"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AnotherToolBox.Views.Controls.Player.StoryCheckView"
             x:DataType="player:StoryCheckViewModel">
    <Border BorderBrush="LightSlateGray" BorderThickness="1" CornerRadius="4">
        <Button Command="{CompiledBinding CheckClick}">
            <StackPanel>
                <!-- <Image></Image> -->
                <TextBlock Text="{CompiledBinding Title}"></TextBlock>
                <TextBlock Text="{CompiledBinding SubTitle}"></TextBlock>
                <TextBlock Text="{CompiledBinding Description}"></TextBlock>
                <CheckBox
                    IsChecked="{CompiledBinding Cleared}"></CheckBox>
            </StackPanel>
        </Button>
    </Border>
</UserControl>
