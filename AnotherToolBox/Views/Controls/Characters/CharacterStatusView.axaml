<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:teamBuilder="clr-namespace:AnotherToolBox.ViewModels.TeamBuilder"
             xmlns:team="clr-namespace:AnotherToolBox.Models.Team"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AnotherToolBox.Views.Controls.Characters.CharacterStatusView"
             x:Name="Root"
             x:DataType="teamBuilder:CharacterStatusViewModel">
    <Control.Styles>
        <Style Selector="Border.StatBorder">
            <Setter Property="BorderThickness" Value="1"></Setter>
            <Setter Property="BorderBrush" Value="DarkSlateGray"></Setter>
            <Setter Property="CornerRadius" Value="4"></Setter>
        </Style>
        <Style Selector="ItemsRepeater.StatsLayout">
            <Setter Property="Layout">
                <UniformGridLayout 
                    Orientation="Horizontal"
                    MaximumRowsOrColumns="2"
                    ItemsJustification="Start"
                    ItemsStretch="Fill"
                    MinColumnSpacing="12"
                    MinRowSpacing="6"
                                   />
            </Setter>
            <Setter Property="ItemTemplate">
                <DataTemplate DataType="team:CharacterStatDto">
                    <Grid ColumnDefinitions="Auto,*" HorizontalAlignment="Stretch">
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,8,0"
                                   Text="{CompiledBinding Stat}" />
                        <TextBlock Grid.Column="1"
                                   Text="{CompiledBinding Value}" />
                    </Grid>
                </DataTemplate>
            </Setter>
        </Style>
    </Control.Styles>
    <Grid 
        ColumnDefinitions="Auto,Auto, Auto"
        ColumnSpacing="10">
        
        <ScrollViewer Grid.Column="0">
            
            <StackPanel Spacing="8">
                
                <!-- show all stats -->
                <Border Classes="StatBorder">
                    <StackPanel>
                        <TextBlock Text="Attack/Def"></TextBlock>
                        <ItemsRepeater
                            Classes="StatsLayout" 
                            ItemsSource="{CompiledBinding AtkStats}">
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border Classes="StatBorder">
                    <StackPanel>
                        <TextBlock Text="Base Stats"></TextBlock>
                        <ItemsRepeater 
                            Classes="StatsLayout" 
                            ItemsSource="{CompiledBinding BaseStats}">
                            </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border Classes="StatBorder">
                    <StackPanel>
                        <TextBlock Text="Critical"></TextBlock>
                        <ItemsRepeater 
                            Classes="StatsLayout" 
                            ItemsSource="{CompiledBinding CritStats}">
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
                <Border Classes="StatBorder">
                    <StackPanel>
                        <TextBlock Text="Type Attack Damage"></TextBlock>
                        <ItemsRepeater 
                            Classes="StatsLayout" 
                            ItemsSource="{CompiledBinding TypeAtkStats}">
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
                <Border Classes="StatBorder">
                    <StackPanel>
                        <TextBlock Text="Type Resistance"></TextBlock>
                        <ItemsRepeater 
                            Classes="StatsLayout" 
                            ItemsSource="{CompiledBinding TypeResStats}">
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
                <Border Classes="StatBorder">
                    <StackPanel>
                        <TextBlock Text="Status Resistances"></TextBlock>
                        <ItemsRepeater 
                            Classes="StatsLayout" 
                            ItemsSource="{CompiledBinding StatusResStats}">
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>
            
        </ScrollViewer>
