<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:teamBuilder="clr-namespace:AnotherToolBox.ViewModels.TeamBuilder"
             xmlns:team="clr-namespace:AnotherToolBox.Models.Team"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AnotherToolBox.Views.Controls.Characters.CharacterEquipmentView"
             x:DataType="teamBuilder:CharacterStatusViewModel"
             x:Name="Root"
             >
      <Control.Styles>
        <Style Selector="Border.StatBorder">
            <Setter Property="BorderThickness" Value="1"></Setter>
            <Setter Property="BorderBrush" Value="DarkSlateGray"></Setter>
            <Setter Property="CornerRadius" Value="4"></Setter>
        </Style>
        <Style Selector="ItemsRepeater.StatsLayout">
            <Setter Property="Layout">
                <UniformGridLayout 
                    Orientation="Horizontal"
                    MaximumRowsOrColumns="2"
                    ItemsJustification="Start"
                    ItemsStretch="Fill"
                    MinColumnSpacing="12"
                    MinRowSpacing="6"
                                   />
            </Setter>
            <Setter Property="ItemTemplate">
                <DataTemplate DataType="team:CharacterStatDto">
                    <Grid ColumnDefinitions="Auto,*" HorizontalAlignment="Stretch">
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,8,0"
                                   Text="{CompiledBinding Stat}" />
                        <TextBlock Grid.Column="1"
                                   Text="{CompiledBinding Value}" />
                    </Grid>
                </DataTemplate>
            </Setter>
        </Style>
    </Control.Styles>
    <Grid 
        ColumnDefinitions="Auto"
        ColumnSpacing="10">
        <Grid Grid.Column="0" MinWidth="260">
            <Border
                BorderBrush="DarkSlateGray"
                BorderThickness="1"
                CornerRadius="4"
                >
                <Grid 
                    ColumnDefinitions="Auto, Auto"
                    RowDefinitions="Auto, Auto, Auto"
                    RowSpacing="4"
                    ColumnSpacing="4"
                    >
                    
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Weapon"></TextBlock>
                        <Button 
                            Command="{CompiledBinding ChangeEquipmentCommand}"
                            CommandParameter="{CompiledBinding WeaponSlot}">
                            <StackPanel>
                                <controls:FASymbolIcon Symbol="Add" IsVisible="{CompiledBinding WeaponSlot.IsEmpty}"/>
                                <TextBlock Text="{CompiledBinding WeaponSlot.SelectedItemName}" IsVisible="{CompiledBinding WeaponSlot.IsSelected}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="Armor"></TextBlock>
                        <Button 
                            Command="{CompiledBinding ChangeEquipmentCommand}"
                            CommandParameter="{CompiledBinding ArmorSlot}">
                            <StackPanel>
                                <controls:FASymbolIcon Symbol="Add" IsVisible="{CompiledBinding ArmorSlot.IsEmpty}"/>
                                <TextBlock Text="{CompiledBinding ArmorSlot.SelectedItemName}" IsVisible="{CompiledBinding ArmorSlot.IsSelected}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <Grid Grid.Row="1" Grid.Column="0" ColumnSpan="2"
                          RowDefinitions="Auto, Auto"
                          ColumnDefinitions="Auto, Auto">
                        <TextBlock Text="Badge" Grid.ColumnSpan="2"></TextBlock>
                        <Button 
                            Grid.Row="1"
                            Grid.Column="0"
                            Command="{CompiledBinding ChangeEquipmentCommand}"
                            CommandParameter="{CompiledBinding BadgeSlots[0]}">
                            <StackPanel>
                                <controls:FASymbolIcon Symbol="Add" IsVisible="{CompiledBinding BadgeSlots[0].IsEmpty}"/>
                                <TextBlock Text="{CompiledBinding BadgeSlots[0].SelectedItemName}" IsVisible="{CompiledBinding BadgeSlots[0].IsSelected}" />
                            </StackPanel>
                        </Button>
                        <Button 
                            Grid.Row="1"
                            Grid.Column="1"
                            Command="{CompiledBinding ChangeEquipmentCommand}"
                            CommandParameter="{CompiledBinding BadgeSlots[1]}">
                            <StackPanel>
                                <controls:FASymbolIcon Symbol="Add" IsVisible="{CompiledBinding BadgeSlots[1].IsEmpty}"/>
                                <TextBlock Text="{CompiledBinding BadgeSlots[1].SelectedItemName}" IsVisible="{CompiledBinding BadgeSlots[1].IsSelected}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Grid Grid.Row="2" Grid.Column="0" ColumnSpan="2"
                          RowDefinitions="Auto, Auto, Auto, Auto, Auto"
                          ColumnDefinitions="Auto, Auto">
                        <TextBlock Text="Grasta" Grid.ColumnSpan="2"></TextBlock>
                        <Button   
                            Grid.Row="1"
                            Grid.Column="0"
                            Command="{CompiledBinding ChangeEquipmentCommand}"
                            CommandParameter="{CompiledBinding GrastaSlots[0]}">
                            <StackPanel>
                                <controls:FASymbolIcon Symbol="Add" IsVisible="{CompiledBinding GrastaSlots[0].IsEmpty}"/>
                                <TextBlock Text="{CompiledBinding GrastaSlots[0].SelectedItemName}" IsVisible="{CompiledBinding GrastaSlots[0].IsSelected}" />
                            </StackPanel>
                        </Button>
                        <Button 
                            Grid.Row="1"
                            Grid.Column="1"
                            Command="{CompiledBinding ChangeEquipmentCommand}"
                            CommandParameter="{CompiledBinding GrastaSlots[1]}">
                            <StackPanel>
                                <controls:FASymbolIcon Symbol="Add" IsVisible="{CompiledBinding GrastaSlots[1].IsEmpty}"/>
                                <TextBlock Text="{CompiledBinding GrastaSlots[1].SelectedItemName}" IsVisible="{CompiledBinding GrastaSlots[1].IsSelected}" />
                            </StackPanel>
                        </Button>
                        <Button 
                            Grid.Row="2"
                            Grid.Column="0"
                            Command="{CompiledBinding ChangeEquipmentCommand}"
                            CommandParameter="{CompiledBinding GrastaSlots[2]}">
                            <StackPanel>
                                <controls:FASymbolIcon Symbol="Add" IsVisible="{CompiledBinding GrastaSlots[2].IsEmpty}"/>
                                <TextBlock Text="{CompiledBinding GrastaSlots[2].SelectedItemName}" IsVisible="{CompiledBinding GrastaSlots[2].IsSelected}" />
                            </StackPanel>
                        </Button>
                        <Button 
                            Grid.Row="2"
                            Grid.Column="1"
                            Command="{CompiledBinding ChangeEquipmentCommand}"
                            CommandParameter="{CompiledBinding GrastaSlots[3]}">
                            <StackPanel>
                                <controls:FASymbolIcon Symbol="Add" IsVisible="{CompiledBinding GrastaSlots[3].IsEmpty}"/>
                                <TextBlock Text="{CompiledBinding GrastaSlots[3].SelectedItemName}" IsVisible="{CompiledBinding GrastaSlots[3].IsSelected}" />
                            </StackPanel>
                        </Button>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Special Grasta" Grid.ColumnSpan="2"></TextBlock>
                        <Button
                            Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                            Command="{CompiledBinding ChangeEquipmentCommand}"
                            CommandParameter="{CompiledBinding SpecialGrastaSlot}">
                            <StackPanel>
                                <controls:FASymbolIcon Symbol="Add" IsVisible="{CompiledBinding SpecialGrastaSlot.IsEmpty}"/>
                                <TextBlock Text="{CompiledBinding SpecialGrastaSlot.SelectedItemName}" IsVisible="{CompiledBinding SpecialGrastaSlot.IsSelected}" />
                            </StackPanel>
                        </Button>
                        
                    </Grid>
                </Grid>
            </Border>
            
            <!-- shared picker overlay -->
            <Border
                Background="#80000000"
                IsVisible="{CompiledBinding IsEquipmentPickerOpen}">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Border
                        Background="White"
                        Padding="12"
                        CornerRadius="6"
                        MinWidth="260"
                        MaxHeight="320">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{CompiledBinding ActiveSlot.Label}" FontWeight="Bold" />

                            <ScrollViewer MaxHeight="220">
                                <ItemsControl ItemsSource="{CompiledBinding AvailableEquipment}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="teamBuilder:EquipmentItemViewModel">
                                            <Button
                                                Command="{CompiledBinding #Root.SelectEquipmentCommandProxy}"
                                                CommandParameter="{CompiledBinding}"
                                                HorizontalAlignment="Stretch">
                                                <TextBlock Text="{CompiledBinding Name}" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Button
                                Content="Cancel"
                                Command="{CompiledBinding CloseEquipmentPickerCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
