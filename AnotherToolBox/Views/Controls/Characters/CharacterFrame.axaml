<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:AnotherToolBox.ViewModels"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:characters="clr-namespace:AnotherToolBox.Views.Controls.Characters"
             xmlns:team="clr-namespace:AnotherToolBox.Views.Controls.Team"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AnotherToolBox.Views.Controls.Characters.CharacterFrame"
             x:DataType="viewModels:CharacterFrameViewModel">
    
    <Grid 
          MinWidth="144"
          MaxWidth="144"
          MinHeight="200"
          MaxHeight="200"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">
        <Button 
            Command="{CompiledBinding SelectCharacter}" 
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel>
                <!-- Add Character when empty -->
                <controls:FASymbolIcon Symbol="Add" 
                                     FontSize="24"
                                     IsVisible="{CompiledBinding SelectedCharacter, Converter={StaticResource ObjectNullBoolConverter}}"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Center"/>
                
                <!-- Show character image + details -->
                <StackPanel 
                    IsVisible="{CompiledBinding SelectedCharacter, Converter={StaticResource ObjectNotNullBoolConverter}}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    >
                    <Image 
                        Source="{CompiledBinding SelectedCharacter.Thumbnail}"
                        Width="120"
                        Height="120"
                        VerticalAlignment="Top"
                        />
                    <TextBlock 
                        Text="{CompiledBinding SelectedCharacter.Name}"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Bottom"
                        TextAlignment="Center"
                        TextWrapping="WrapWithOverflow"
                        MaxLines="2"
                        MaxWidth="120" 
                        Height="40"
                        />
                    <StackPanel Orientation="Horizontal">
                        
                        <Button Command="{CompiledBinding ViewStats}">
                            <controls:FASymbolIcon Symbol="BulletList"></controls:FASymbolIcon>
                            <Button.Flyout>
                                <Flyout
                                    IsOpen="{CompiledBinding StatsOpen}"
                                        Closing="StatsFlyout_OnClosing">
                                    <characters:CharacterStatusView 
                                        DataContext="{CompiledBinding CharacterStatusVm}"
                                        Height="340"/>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button Command="{CompiledBinding ViewEquipment}">
                            <controls:FASymbolIcon Symbol="XboxConsole"></controls:FASymbolIcon>
                            <Button.Flyout>
                                <Flyout
                                    IsOpen="{CompiledBinding EquipmentOpen}"
                                    Closing="StatsFlyout_OnClosing">
                                    <characters:CharacterEquipmentView 
                                        DataContext="{CompiledBinding CharacterStatusVm}"
                                        Height="340"/>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button Command="{CompiledBinding ViewSkills}">
                            <controls:FASymbolIcon Symbol="StarAdd"></controls:FASymbolIcon>
                            <Button.Flyout>
                                <Flyout
                                    IsOpen="{CompiledBinding SkillsOpen}"
                                    Closing="StatsFlyout_OnClosing">
                                    <characters:CharacterSkillsView 
                                        DataContext="{CompiledBinding CharacterStatusVm}"
                                        Height="340"/>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <Button.Flyout>
                <Flyout IsOpen="{CompiledBinding SelectorOpen}"
                        Closing="PopupFlyoutBase_OnClosing">
                    <characters:CharacterList 
                        DataContext="{CompiledBinding CharacterListVm}"
                        Width="240"
                        Height="300"/>
                </Flyout>
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>
