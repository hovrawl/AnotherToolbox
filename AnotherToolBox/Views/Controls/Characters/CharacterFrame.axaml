<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:AnotherToolBox.ViewModels"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:characters="clr-namespace:AnotherToolBox.Views.Controls.Characters"
             xmlns:team="clr-namespace:AnotherToolBox.Views.Controls.Team"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AnotherToolBox.Views.Controls.Characters.CharacterFrame"
             x:DataType="viewModels:CharacterFrameViewModel">
    
    <Grid 
          MinWidth="144"
          MaxWidth="144"
          MinHeight="170"
          MaxHeight="190"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">
        <Button 
            Command="{Binding SelectCharacter}" 
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel>
                <!-- Add Character when empty -->
                <controls:SymbolIcon Symbol="Add" 
                                     FontSize="24"
                                     IsVisible="{Binding SelectedCharacter, Converter={StaticResource ObjectNullBoolConverter}}"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Center"/>
                
                <!-- Show character image + details -->
                <StackPanel 
                    IsVisible="{Binding SelectedCharacter, Converter={StaticResource ObjectNotNullBoolConverter}}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    >
                    <Image 
                        Source="{Binding SelectedCharacter.Thumbnail}"
                        Width="120"
                        Height="120"
                        VerticalAlignment="Top"
                        />
                    <TextBlock 
                        Text="{Binding SelectedCharacter.Name}"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Bottom"
                        TextAlignment="Center"
                        TextWrapping="WrapWithOverflow"
                        MaxLines="2"
                        MaxWidth="120" 
                        Height="40"
                        />
                    <Button Command="{Binding ViewStats}" >
                        Stats
                        <Button.Flyout>
                            <Flyout
                                IsOpen="{Binding StatsOpen}"
                                    Closing="StatsFlyout_OnClosing">
                                <team:CharacterStatusView 
                                    DataContext="{Binding CharacterStatusVm}"
                                    Height="340"/>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </StackPanel>
            <Button.Flyout>
                <Flyout IsOpen="{Binding SelectorOpen}"
                        Closing="PopupFlyoutBase_OnClosing">
                    <characters:CharacterList 
                        DataContext="{Binding CharacterListVm}"
                        Width="240"
                        Height="300"/>
                </Flyout>
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>
