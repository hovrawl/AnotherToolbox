<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:teamBuilder="clr-namespace:AnotherToolBox.ViewModels.TeamBuilder"
             xmlns:team="clr-namespace:AnotherToolBox.Models.Team"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AnotherToolBox.Views.Controls.Team.CharacterStatusView"
             x:DataType="teamBuilder:CharacterStatusViewModel">
    <Control.Styles>
        <Style Selector="Border.StatBorder">
            <Setter Property="BorderThickness" Value="1"></Setter>
            <Setter Property="BorderBrush" Value="DarkSlateGray"></Setter>
            <Setter Property="CornerRadius" Value="4"></Setter>
        </Style>
        <Style Selector="ItemsRepeater.StatsLayout">
            <Setter Property="Layout">
                <UniformGridLayout 
                    Orientation="Horizontal"
                    MaximumRowsOrColumns="2"
                    ItemsJustification="Start"
                    ItemsStretch="Fill"
                    MinColumnSpacing="12"
                    MinRowSpacing="6"
                                   />
            </Setter>
            <Setter Property="ItemTemplate">
                <DataTemplate DataType="team:CharacterStatDto">
                    <Grid ColumnDefinitions="Auto,*" HorizontalAlignment="Stretch">
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,8,0"
                                   Text="{Binding Stat}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Value}" />
                    </Grid>
                </DataTemplate>
            </Setter>
        </Style>
    </Control.Styles>
    <ScrollViewer>
        
        <StackPanel Spacing="8">
            
            <!-- show all stats -->
            <Border Classes="StatBorder">
                <StackPanel>
                    <TextBlock Text="Attack/Def"></TextBlock>
                    <ItemsRepeater
                        Classes="StatsLayout" 
                        ItemsSource="{Binding AtkStats}">
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <Border Classes="StatBorder">
                <StackPanel>
                    <TextBlock Text="Base Stats"></TextBlock>
                    <ItemsRepeater 
                        Classes="StatsLayout" 
                        ItemsSource="{Binding BaseStats}">
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <Border Classes="StatBorder">
                <StackPanel>
                    <TextBlock Text="Critical"></TextBlock>
                    <ItemsRepeater 
                        Classes="StatsLayout" 
                        ItemsSource="{Binding CritStats}">
                    </ItemsRepeater>
                </StackPanel>
            </Border>
            <Border Classes="StatBorder">
                <StackPanel>
                    <TextBlock Text="Type Attack Damage"></TextBlock>
                    <ItemsRepeater 
                        Classes="StatsLayout" 
                        ItemsSource="{Binding TypeAtkStats}">
                    </ItemsRepeater>
                </StackPanel>
            </Border>
            <Border Classes="StatBorder">
                <StackPanel>
                    <TextBlock Text="Type Resistance"></TextBlock>
                    <ItemsRepeater 
                        Classes="StatsLayout" 
                        ItemsSource="{Binding TypeResStats}">
                    </ItemsRepeater>
                </StackPanel>
            </Border>
            <Border Classes="StatBorder">
                <StackPanel>
                    <TextBlock Text="Status Resistances"></TextBlock>
                    <ItemsRepeater 
                        Classes="StatsLayout" 
                        ItemsSource="{Binding StatusResStats}">
                    </ItemsRepeater>
                </StackPanel>
            </Border>
        </StackPanel>
        
    </ScrollViewer>
    <!-- ~1~ Loading overlay @1@ -->
    <!-- <Border  Background="#80000000" IsVisible="{Binding IsLoading}"> -->
    <!--     <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"> -->
    <!--         <controls:ProgressRing IsIndeterminate="True" Width="40" Height="40" /> -->
    <!--         <TextBlock Text="Loading..." Foreground="White" HorizontalAlignment="Center" /> -->
    <!--     </StackPanel> -->
    <!-- </Border> -->
</UserControl>
