<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AnotherToolBox.App"
             xmlns:local="using:AnotherToolBox"
             xmlns:styling="clr-namespace:FluentAvalonia.Styling;assembly=FluentAvalonia"
             xmlns:converters="clr-namespace:AnotherToolBox.Converters"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <styling:FluentAvaloniaTheme />
    </Application.Styles>
             
     <Application.Resources>
         <converters:IndexToDividerVisibilityConverter x:Key="IndexToDividerVisibilityConverter" />
         <converters:ObjectNotNullToBoolConverter x:Key="ObjectNotNullBoolConverter" />
         <converters:ObjectNullToBoolConverter x:Key="ObjectNullBoolConverter" />
     </Application.Resources> 
</Application>